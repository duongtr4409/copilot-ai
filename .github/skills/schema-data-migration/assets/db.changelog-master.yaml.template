databaseChangeLog:
  - changeSet:
      id: V1-initial-schema
      author: team
      labels: baseline
      context: dev,staging,prod
      comment: Bootstrap initial schema
      changes:
        - sqlFile:
            path: ./V1__initial_schema.sql.template
            relativeToChangelogFile: true
            splitStatements: true
            stripComments: false

